{
  "version": "1.0.0",
  "project": "ClawReviewer",
  "model_routing": {
    "base_url": "https://generativelanguage.googleapis.com/v1beta/openai/",
    "api_key_env": "GOOGLE_AI_STUDIO_API_KEY",
    "default_temperature": 0.2,
    "default_max_tokens": 8192
  },
  "agents": {
    "scout": {
      "model": "google/gemini-2.0-flash",
      "role": "Repository structure analysis and file discovery",
      "temperature": 0.1,
      "max_tokens": 4096,
      "system_prompt_key": "scout"
    },
    "coder": {
      "model": "google/gemini-2.0-flash",
      "role": "Code modification and patch generation",
      "temperature": 0.15,
      "max_tokens": 8192,
      "system_prompt_key": "coder"
    },
    "planner": {
      "model": "google/gemini-2.0-flash-thinking-exp",
      "role": "Strategic optimization planning and task decomposition",
      "temperature": 0.2,
      "max_tokens": 16384,
      "system_prompt_key": "planner"
    },
    "critic": {
      "model": "google/gemini-2.0-flash-thinking-exp",
      "role": "Code review, failure analysis, and self-healing guidance",
      "temperature": 0.2,
      "max_tokens": 16384,
      "system_prompt_key": "critic"
    },
    "reviewer": {
      "model": "google/gemini-2.0-flash-thinking-exp",
      "role": "Pull request generation and release note authoring",
      "temperature": 0.3,
      "max_tokens": 16384,
      "system_prompt_key": "reviewer"
    }
  },
  "pipeline": {
    "branch_name": "openclaw/optimization-patch",
    "todo_file": "todo.json",
    "max_self_heal_retries": 3,
    "test_timeout_seconds": 300,
    "commit_only_on_clean_tests": true,
    "git_author_name": "OpenClaw Bot",
    "git_author_email": "openclaw-bot@clawreviewer.ai"
  },
  "sandbox": {
    "runtime": "NemoClaw/OpenShell",
    "allow_network": true,
    "allow_git": true,
    "allow_subprocess": true,
    "working_dir_env": "OPENCLAW_REPO_PATH"
  }
}
